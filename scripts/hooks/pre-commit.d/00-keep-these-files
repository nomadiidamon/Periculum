#!/bin/sh

echo "Checking protected files and directories..."

PROTECTED_ITEMS="
Config/
Content/
Docs/
Plugins/
scripts/
Source/
tools/
.clang-format
.clang-tidy
Doxyfile
"

FAILED=0

DELETED_FILES=$(git diff --cached --name-status --diff-filter=D)

for entry in $DELETED_FILES; do
    status=$(echo "$entry" | cut -f1)
    file=$(echo "$entry" | cut -f2-)

    for protected in $PROTECTED_ITEMS; do

        case "$file" in
            "$protected"*)
                echo
                echo "ERROR: Protected item removed:"
                echo "  $file"
                FAILED=1
                ;;
        esac

    done

    case "$file" in
        *.uproject)
            echo
            echo "ERROR: Protected Unreal project file removed:"
            echo "  $file"
            FAILED=1
            ;;
    esac
done

if [ "$FAILED" -eq 1 ]; then
    echo
    echo "ERROR: Protected files/directories cannot be removed."
    exit 1
fi

echo "Protected file check passed."

exit 0
