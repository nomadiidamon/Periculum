#!/bin/sh

echo "Checking file encodings..."

FILES=$(git diff --cached --name-only --diff-filter=ACM | \
  grep -Ei '\.(h|hpp|cpp|c|md|txt|doxy)$' || true)

if [ -z "$FILES" ]; then
    echo "No text files to check."
    exit 0
fi

BAD_FILES=""

for FILE in $FILES; do
    if [ -f "$FILE" ]; then
        RESULT=$(file -i "$FILE")

        echo "$RESULT" | grep -qE "charset=(utf-8|us-ascii)"

        if [ $? -ne 0 ]; then
            BAD_FILES="$BAD_FILES\n$RESULT"
        fi
    fi
done

if [ -n "$BAD_FILES" ]; then
    echo ""
    echo "ERROR: The following files are not UTF-8 compatible:"
    echo -e "$BAD_FILES"
    echo ""
    echo "Convert these files to UTF-8 before committing."
    exit 1
fi

echo "Encoding check passed."
exit 0